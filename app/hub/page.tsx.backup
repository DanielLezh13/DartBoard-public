            { id: "free", name: "Free", price: "$0", features: ["Basic memory management", "Up to 100 memories", "Community support"] },
            { id: "pro", name: "Pro", price: "$19/mo", features: ["Advanced memory features", "Unlimited memories", "Priority support", "Advanced search"] },
            { id: "team", name: "Team", price: "$49/mo", features: ["Everything in Pro", "Team collaboration", "Admin controls", "SLA guarantee"] },
