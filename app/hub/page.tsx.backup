"use client";

import React, { useState, useEffect, useRef } from "react"
import Link from "next/link"
import { useSearchParams, useRouter } from "next/navigation"
import { MessageCircle, Archive, Eye, EyeOff, Mail, Lock } from "lucide-react"
import { SignInCard } from "@/components/sign-in-card"

// Interactive cursor glow component
const CursorGlow = () => {
  const [mousePos, setMousePos] = useState({ x: 0, y: 0 })
  const [isVisible, setIsVisible] = useState(false)
  const targetRef = useRef({ x: 0, y: 0 })
  const currentRef = useRef({ x: 0, y: 0 })
  const rafRef = useRef<number>(0)

  useEffect(() => {
    const handleMouseMove = (e: MouseEvent) => {
      targetRef.current = { x: e.clientX, y: e.clientY }
      if (!isVisible) setIsVisible(true)
    }

    const handleMouseLeave = () => {
      setIsVisible(false)
    }

    // Smooth animation loop
    const animate = () => {
      const lerp = 0.08
      currentRef.current.x += (targetRef.current.x - currentRef.current.x) * lerp
      currentRef.current.y += (targetRef.current.y - currentRef.current.y) * lerp
      setMousePos({ x: currentRef.current.x, y: currentRef.current.y })
      rafRef.current = requestAnimationFrame(animate)
    }

    window.addEventListener("mousemove", handleMouseMove)
    document.addEventListener("mouseleave", handleMouseLeave)
    rafRef.current = requestAnimationFrame(animate)

    return () => {
      window.removeEventListener("mousemove", handleMouseMove)
      document.removeEventListener("mouseleave", handleMouseLeave)
      cancelAnimationFrame(rafRef.current)
    }
  }, [isVisible])

  return (
    <div
      className="pointer-events-none fixed inset-0 z-0 transition-opacity duration-500"
      style={{ opacity: isVisible ? 1 : 0 }}
    >
      {/* Primary glow blob */}
      <div
        className="absolute w-[600px] h-[600px] rounded-full"
        style={{
          left: mousePos.x - 300,
          top: mousePos.y - 300,
          background: "radial-gradient(circle, rgba(56,189,248,0.15) 0%, rgba(56,189,248,0.05) 40%, transparent 70%)",
          filter: "blur(40px)",
        }}
      />
      {/* Secondary smaller glow */}
      <div
        className="absolute w-[300px] h-[300px] rounded-full"
        style={{
          left: mousePos.x - 150,
          top: mousePos.y - 150,
          background: "radial-gradient(circle, rgba(147,197,253,0.1) 0%, transparent 60%)",
          filter: "blur(20px)",
        }}
      />
    </div>
  )
}

// Custom DartBoard icon
const IconDartboard = ({ className }: { className?: string }) => (
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
    className={className}
  >
    <circle cx="12" cy="12" r="10" />
    <circle cx="12" cy="12" r="6" />
    <circle cx="12" cy="12" r="2" />
  </svg>
)

// Apps data structure
const apps = [
  {
    id: "chat",
    title: "Chat",
    desc: "Primary LYNX interface",
    href: "/chat",
    appId: "assistant",
    icon: <MessageCircle size={22} className="text-sky-400" />,
  },
  {
    id: "dartboard",
    title: "DartBoard",
    desc: "Welcome to DartBoard",
    href: "/vault",
    appId: "dartboard",
    icon: <IconDartboard className="w-5 h-5 text-sky-400" />,
  },
  {
    id: "archive",
    title: "Archive",
    desc: "ChatGPT Logs Search",
    href: "/archive",
    appId: "archive",
    icon: <Archive size={22} className="text-slate-300" />,
  },
]

type TabType = "chat" | "dartboard" | "archive"
type PanelType = "auth" | "welcome"
type TierType = "free" | "pro" | "team"

export default function HubPage() {
  const searchParams = useSearchParams()
  const router = useRouter()
  const [selectedTab, setSelectedTab] = useState<TabType>("dartboard")
  const [selectedTier, setSelectedTier] = useState<TierType>("free")
  const [profile, setProfile] = useState<any>(null)
  const [isLoading, setIsLoading] = useState(true)
  const isInSplit = searchParams.has("right")

  useEffect(() => {
    // Simulate loading user profile
    const timer = setTimeout(() => {
      setProfile({ display_name: "daniel" })
      setIsLoading(false)
    }, 100)
    return () => clearTimeout(timer)
  }, [])

  const handleTabSelect = (tabId: TabType) => {
    setSelectedTab(tabId)
  }

  const handleAppClick = (appId: string, href: string) => {
    if (isInSplit) {
      const currentLeft = searchParams.get("left") || "hub"
      if (currentLeft === "hub" && appId === "assistant") {
        const newParams = new URLSearchParams()
        newParams.set("right", appId)
        router.push(`/${currentLeft}?${newParams.toString()}`)
      } else {
        router.push(href)
      }
    } else {
      router.push(href)
    }
  }

  const getPanelType = (): PanelType => {
    return selectedTab === "dartboard" ? "welcome" : "auth"
  }

  const getTierSubtitle = () => {
    switch (selectedTier) {
      case "free":
        return "Basic memory management"
      case "pro":
        return "Advanced features & priority support"
      case "team":
        return "Collaboration & admin controls"
      default:
        return ""
    }
  }

  // Glass card component for top navigation
  const HubTopCard = ({
    app,
    isActive,
    onClick,
  }: {
    app: (typeof apps)[number]
    isActive: boolean
    onClick: () => void
  }) => {
    return (
      <Link
        href={app.href}
        onClick={onClick}
        className={`group relative rounded-2xl px-6 py-5 min-h-[100px] w-full h-full flex items-center transition-all duration-300 cursor-pointer
          bg-white/[0.04] backdrop-blur-2xl border border-white/[0.08]
          shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_4px_24px_rgba(0,0,0,0.3)]
          hover:-translate-y-0.5 hover:bg-white/[0.07] hover:border-white/[0.15] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_8px_32px_rgba(56,189,248,0.1)]
          ${isActive ? "border-sky-500/40 bg-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.1),0_0_20px_rgba(56,189,248,0.15)]" : ""}
        `}
      >
        {/* Inner highlight */}
        <div className="absolute inset-0 rounded-2xl bg-gradient-to-b from-white/[0.03] to-transparent pointer-events-none" />

        <div className="flex items-center gap-3 relative z-10">
          {/* Icon chip */}
          <div className="rounded-xl bg-white/[0.06] border border-white/[0.08] p-2.5 flex-shrink-0">
            <div className="w-5 h-5 flex items-center justify-center">{app.icon}</div>
          </div>

          {/* Text stack */}
          <div className="flex flex-col">
            <h3
              className={`text-base font-semibold leading-tight ${app.id === "dartboard" ? "text-sky-400" : "text-white/90"}`}
            >
              {app.title}
            </h3>
            <p className="text-sm text-white/50 leading-tight mt-1">{app.desc}</p>
          </div>
        </div>
      </Link>
    )
  }

  // Glass info card component
  const InfoCard = ({ title, children }: { title: string; children: React.ReactNode }) => (
    <div
      className="relative rounded-2xl p-6 w-full h-full min-h-[460px]
      bg-white/[0.04] backdrop-blur-2xl border border-white/[0.08]
      shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_4px_24px_rgba(0,0,0,0.3)]"
    >
      {/* Inner highlight */}
      <div className="absolute inset-0 rounded-2xl bg-gradient-to-b from-white/[0.03] to-transparent pointer-events-none" />

      <div className="relative z-10">
        <h2 className="text-lg font-semibold text-white/90 mb-4">{title}</h2>
        <div className="text-sm text-white/60 leading-relaxed space-y-3">{children}</div>
      </div>
    </div>
  )

  // Welcome panel for DartBoard
  const WelcomePanel = () => (
    <div
      className="relative rounded-2xl p-6 w-full h-full min-h-[460px]
      bg-white/[0.04] backdrop-blur-2xl border border-white/[0.08]
      shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_4px_24px_rgba(0,0,0,0.3)]"
