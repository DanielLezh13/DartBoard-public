      <div className="absolute inset-0 rounded-2xl bg-gradient-to-b from-white/[0.03] to-transparent pointer-events-none" />

      <div className="relative z-10">
        <div className="text-center mb-6">
          <IconDartboard className="w-12 h-12 text-sky-400 mx-auto mb-4" />
          <h2 className="text-xl font-semibold text-white/90 mb-1">Welcome to DartBoard</h2>
          <p className="text-sm text-white/50">Choose your plan to get started</p>
        </div>

        <div className="space-y-3">
