  return (
    <div className="min-h-screen bg-slate-950 relative overflow-hidden">
      {/* Interactive cursor glow */}
      <CursorGlow />
      
      {/* Static ambient background */}
      <div className="absolute inset-0 overflow-hidden pointer-events-none">
        {/* Subtle base glow */}
