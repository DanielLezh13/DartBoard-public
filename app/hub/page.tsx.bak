"use client";

import React, { useState, useEffect, useRef } from "react"
import Link from "next/link"
import { useSearchParams, useRouter } from "next/navigation"
import { MessageCircle, Archive, Eye, EyeOff, Mail, Lock } from "lucide-react"
import { SignInCard } from "@/components/sign-in-card"
import { motion } from "framer-motion"
import { cardVariants, cardBlurVariants, rowVariants, contentFade } from "./animations"
import { createClient } from "@/lib/supabase/client"
import type { User } from "@supabase/supabase-js"

// Interactive cursor glow component
const CursorGlow = () => {
  const [mousePos, setMousePos] = useState({ x: 0, y: 0 })
  const [isVisible, setIsVisible] = useState(false)
  const targetRef = useRef({ x: 0, y: 0 })
  const currentRef = useRef({ x: 0, y: 0 })
  const rafRef = useRef<number>(0)

  useEffect(() => {
    const handleMouseMove = (e: MouseEvent) => {
      targetRef.current = { x: e.clientX, y: e.clientY }
      if (!isVisible) setIsVisible(true)
    }

    const handleMouseLeave = () => {
      setIsVisible(false)
    }

    // Smooth animation loop
    const animate = () => {
      const lerp = 0.08
      currentRef.current.x += (targetRef.current.x - currentRef.current.x) * lerp
      currentRef.current.y += (targetRef.current.y - currentRef.current.y) * lerp
      setMousePos({ x: currentRef.current.x, y: currentRef.current.y })
      rafRef.current = requestAnimationFrame(animate)
    }

    window.addEventListener("mousemove", handleMouseMove)
    document.addEventListener("mouseleave", handleMouseLeave)
    rafRef.current = requestAnimationFrame(animate)

    return () => {
      window.removeEventListener("mousemove", handleMouseMove)
      document.removeEventListener("mouseleave", handleMouseLeave)
      cancelAnimationFrame(rafRef.current)
    }
  }, [isVisible])

  return (
    <div
      className="pointer-events-none fixed inset-0 z-0 transition-opacity duration-500"
      style={{ opacity: isVisible ? 1 : 0 }}
    >
      {/* Primary glow blob */}
      <div
        className="absolute w-[600px] h-[600px] rounded-full"
        style={{
          left: mousePos.x - 300,
          top: mousePos.y - 300,
          background: "radial-gradient(circle, rgba(56,189,248,0.15) 0%, rgba(56,189,248,0.05) 40%, transparent 70%)",
          filter: "blur(40px)",
        }}
      />
      {/* Secondary smaller glow */}
      <div
        className="absolute w-[300px] h-[300px] rounded-full"
        style={{
          left: mousePos.x - 150,
          top: mousePos.y - 150,
          background: "radial-gradient(circle, rgba(147,197,253,0.1) 0%, transparent 60%)",
          filter: "blur(20px)",
        }}
      />
    </div>
  )
}

// Custom DartBoard icon
const IconDartboard = ({ className }: { className?: string }) => (
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
    className={className}
  >
    <circle cx="12" cy="12" r="10" />
    <circle cx="12" cy="12" r="6" />
    <circle cx="12" cy="12" r="2" />
  </svg>
)

// Apps data structure
const apps = [
  {
    id: "chat",
    title: "Chat",
    desc: "Primary LYNX interface",
    href: "/chat",
    icon: <MessageCircle size={22} className="text-sky-400" />,
  },
  {
    id: "dartboard",
    title: "DartBoard",
    desc: "Welcome to DartBoard",
    href: "/vault",
    icon: <IconDartboard className="w-5 h-5 text-sky-400" />,
  },
  {
    id: "archive",
    title: "Archive",
    desc: "ChatGPT Logs Search",
    href: "/archive",
    icon: <Archive size={22} className="text-sky-400" />,
  },
]

// Glass card component for top navigation
const HubTopCard = ({
  app,
  isActive,
  onClick,
  activeCardId,
  isMobile,
}: {
  app: (typeof apps)[number]
  isActive: boolean
  onClick: React.MouseEventHandler<HTMLButtonElement>
  activeCardId: string | null
  isMobile: boolean
}) => {
  const isExpanded = isMobile && activeCardId === app.id
  
  return (
    <button
      onClick={onClick}
      className={`group relative isolate overflow-hidden rounded-2xl px-6 py-5 min-h-[100px] w-full h-full flex items-center transition-all duration-300 cursor-pointer
        shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_4px_24px_rgba(0,0,0,0.3)]
        hover:-translate-y-1 hover:scale-[1.02] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_12px_40px_rgba(0,0,0,0.4),0_0_30px_rgba(59,130,246,0.3)]
        ${isActive 
          ? "bg-gradient-to-r from-blue-600/10 to-purple-600/10" 
          : "bg-gradient-to-r from-blue-600/5 to-purple-600/5 hover:from-blue-600/7 hover:to-purple-600/7"
        }
        ${isExpanded ? "ring-1 ring-white/25 shadow-[0_12px_50px_rgba(59,130,246,0.18)] min-h-[120px]" : "ring-1 ring-blue-400/30"}
      `}
    >
      {/* Inner highlight */}
      <div className="pointer-events-none absolute inset-0 rounded-2xl bg-gradient-to-b from-white/[0.03] to-transparent" />

      <motion.div 
        variants={cardBlurVariants}
        initial="hidden"
        animate="show"
        className="flex items-center gap-3 relative z-10 w-full"
      >
        {/* Icon chip */}
        <div className="rounded-xl bg-white/[0.06] border border-white/[0.08] p-2 flex-shrink-0">
          <div className="w-5 h-5 flex items-center justify-center">{app.icon}</div>
        </div>

        {/* Text stack */}
        <div className="flex flex-col items-start">
          <h3
            className={`text-base font-semibold leading-tight ${
              app.id === "dartboard" ? "text-blue-400" : "text-white/90"
            }`}
          >
            {app.title}
          </h3>
          <p className="text-sm text-white/55 leading-tight mt-0.5">{app.desc}</p>
          {isExpanded && (
            <p className="text-xs text-white/40 mt-2">Tap again to open</p>
          )}
        </div>
      </motion.div>
    </button>
  )
}

// Glass info card component
const InfoCard = ({ title, children }: { title: string; children: React.ReactNode }) => (
  <div
    className="relative isolate overflow-hidden rounded-2xl p-6 w-full h-full min-h-[460px]
    bg-white/[0.04] backdrop-blur-2xl border border-white/[0.08]
    shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_4px_24px_rgba(0,0,0,0.3)]"
  >
    {/* Inner highlight */}
    <div className="pointer-events-none absolute inset-0 rounded-2xl bg-gradient-to-b from-white/[0.03] to-transparent" />

    <motion.div 
      variants={cardBlurVariants}
      initial="hidden"
      animate="show"
      className="relative z-10"
    >
      <h2 className="text-lg font-semibold text-white/90 mb-4">{title}</h2>
      <div className="text-sm text-white/60 leading-relaxed space-y-3">{children}</div>
    </motion.div>
  </div>
)

export default function HubPage() {
  const searchParams = useSearchParams()
  const router = useRouter()
  const [selectedTab, setSelectedTab] = useState<string>("dartboard")
  const [selectedTier, setSelectedTier] = useState<string>("free")
  const [showPlans, setShowPlans] = useState<boolean>(false)
  const [activeCardId, setActiveCardId] = useState<string | null>(null)
  const [profile, setProfile] = useState<any>(null)
  const [isLoading, setIsLoading] = useState(true)
  const [user, setUser] = useState<User | null>(null)
  const isInSplit = searchParams.has("right")
  const [isMobile, setIsMobile] = useState(false)
  const supabase = createClient()
  const next = searchParams.get('next')

  useEffect(() => {
    const checkMobile = () => setIsMobile(window.innerWidth < 1024)
    checkMobile()
    window.addEventListener('resize', checkMobile)
    return () => window.removeEventListener('resize', checkMobile)
  }, [])

  useEffect(() => {
    // Check for existing session
    const getSession = async () => {
      const { data: { session } } = await supabase.auth.getSession()
      setUser(session?.user ?? null)
      
      // If user is authenticated and there's a next parameter, redirect
      if (session?.user && next) {
        router.push(next)
        return
      }
      
      // Simulate loading user profile
      const timer = setTimeout(() => {
        setProfile({ display_name: session?.user?.email?.split('@')[0] || "daniel" })
        setIsLoading(false)
      }, 100)
      return () => clearTimeout(timer)
    }
    
    getSession()
    
    // Listen for auth changes
    const { data: { subscription } } = supabase.auth.onAuthStateChange((_event, session) => {
      setUser(session?.user ?? null)
      if (session?.user && next) {
        router.push(next)
      }
    })
    
    return () => subscription.unsubscribe()
  }, [supabase, router, next])

  const handleTabSelect = (tabId: string) => {
    setSelectedTab(tabId)
  }

  const handleCardTap = (e: React.MouseEvent, cardId: string, action: () => void) => {
    if (!isMobile) return action()

    if (activeCardId !== cardId) {
      e.preventDefault()
      e.stopPropagation()
      setActiveCardId(cardId)
      return
    }

    // Second tap while active -> do action
    action()
  }

  const handleSignOut = async () => {
    await supabase.auth.signOut()
    router.push('/hub')
  }

  if (isLoading) {
    return (
      <div className="min-h-screen bg-slate-950 flex items-center justify-center">
        <div className="text-white/50">Loading...</div>
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-slate-950 relative overflow-hidden">
      {/* Interactive cursor glow */}
      <CursorGlow />
      
      {/* Static ambient background */}
      <div className="absolute inset-0 overflow-hidden pointer-events-none">
        {/* Subtle base glow */}
        <div className="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-sky-500/[0.03] rounded-full blur-3xl" />
      </div>

      {/* Main content */}
      <div className="relative z-10 flex flex-col items-center py-12">
        <div className="w-full px-12">
          {/* Top navigation cards */}
          <motion.div
            variants={rowVariants(0.05)}
            initial="hidden"
            animate="show"
            className="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-8 items-stretch mb-8"
          >
            {apps.map((app) => (
              <motion.div key={app.id} variants={cardVariants}>
                <HubTopCard
                  app={app}
                  isActive={selectedTab === app.id}
                  activeCardId={activeCardId}
                  isMobile={isMobile}
                  onClick={(e: React.MouseEvent) => {
                    if (app.id === "dartboard") {
                      handleCardTap(e, app.id, () => {
                        setShowPlans(true)
                        setSelectedTab("dartboard")
                      })
                    } else {
                      handleCardTap(e, app.id, () => {
                        handleTabSelect(app.id)
                        router.push(app.href)
                      })
                    }
                  }}
                />
              </motion.div>
            ))}
          </motion.div>

          {/* Second row - Always show all 3 cards */}
          <motion.div
            variants={rowVariants(0.35)}
            initial="hidden"
            animate="show"
            className="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-8 items-stretch"
          >
            {/* Chat Interface Info Card */}
            <motion.div variants={cardVariants} className="w-full h-full min-h-[420px] order-1 lg:order-1">
              <InfoCard title="Chat Interface">
                <motion.div
                  variants={contentFade}
                  initial="hidden"
                  animate="show"
                  transition={{ delay: 0.70 }}
                >
                  <p>
                    Chat is the primary interface for interacting with the model in DartBoard.
                  </p>
                  <p>
                    Unlike standard chat systems, conversations here are memory-aware and context-controlled, giving you
                    direct oversight of what information the model can access at any moment. You can attach memories, pin or
                    unpin them to control prompt injection, switch operational modes, and observe how context changes affect
                    responses in real time.
                  </p>
                  <p>
                    Beyond live interaction, Chat functions as a persistent working environment. You can save and edit
                    messages as reusable memories, search across sessions by keyword, and navigate conversations using
                    time-based buckets. The goal is not simply to talk to an AI, but to run structured, intentional
                    interactions where context is explicit, controllable, and never lost to scrollback.
                  </p>
                </motion.div>
              </InfoCard>
            </motion.div>

            {/* Center Card - Sign In or User Info */}
            <motion.div variants={cardVariants} className="w-full h-full min-h-[420px] relative order-3 lg:order-2">
              {!user ? (
                <SignInCard />
              ) : (
                <div className="w-full rounded-2xl p-10 bg-white/8 backdrop-blur-md border border-white/10 shadow-[0_20px_60px_rgba(0,0,0,0.35)] relative isolate overflow-hidden">
                  {/* Top edge highlight */}
                  <div className="absolute inset-0 rounded-2xl bg-gradient-to-b from-white/10 to-transparent [mask-image:linear-gradient(to_bottom,black_40%,transparent)]"></div>
                  {/* Inner shadow */}
                  <div className="absolute inset-0 rounded-2xl shadow-inner [box-shadow:inset_0_1px_0_rgba(255,255,255,0.06)] pointer-events-none"></div>
                  
                  <div className="relative z-10">
                    <div className="text-center mb-6">
                      <h2 className="text-2xl font-semibold text-white/90">Welcome back, {profile?.display_name}</h2>
                      <p className="text-white/65 text-sm mt-1">{user.email}</p>
                    </div>
                    
                    <div className="space-y-4">
                      <button
                        onClick={() => router.push('/chat')}
                        className="w-full py-3 px-4 bg-white/10 hover:bg-white/15 border border-white/20 rounded-xl font-medium
                          text-white hover:border-white/30 active:bg-white/5 transition-all duration-200"
                      >
                        Go to Chat
                      </button>
                      
                      <button
                        onClick={handleSignOut}
                        className="w-full py-3 px-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl font-medium
                          text-white/70 hover:text-white hover:border-white/20 transition-all duration-200"
                      >
                        Sign Out
                      </button>
                    </div>
                  </div>
                </div>
              )}
              
              {/* Plans overlay */}
              {showPlans && (
                <div 
                  className="absolute inset-0 z-50 flex items-center justify-center"
                  onClick={() => setShowPlans(false)}
                >
                  <div 
                    className="absolute inset-0 bg-black/50 backdrop-blur-sm rounded-2xl"
                  />
                  <div 
                    className="relative bg-slate-900/95 rounded-2xl p-8 border border-white/10 shadow-2xl w-full max-w-md"
                    onClick={(e) => e.stopPropagation()}
                  >
                    <div className="flex justify-between items-center mb-6">
                      <h2 className="text-xl font-semibold text-white/90">Choose Your Plan</h2>
                      <button
                        onClick={() => setShowPlans(false)}
                        className="text-white/40 hover:text-white/60 transition-colors"
                      >
                        <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      </button>
                    </div>
                    
                    <div className="space-y-3">
                      {[
                        { id: "free", name: "Free", price: "$0", features: ["Basic memory management", "Up to 100 memories", "Community support"] },
                        { id: "pro", name: "Pro", price: "$19/mo", features: ["Advanced memory features", "Unlimited memories", "Priority support", "Advanced search"] },
                        { id: "team", name: "Team", price: "$49/mo", features: ["Everything in Pro", "Team collaboration", "Admin controls", "SLA guarantee"] },
                      ].map((tier) => (
                        <button
                          key={tier.id}
                          onClick={() => setSelectedTier(tier.id)}
                          className={`w-full p-4 rounded-xl border transition-all text-left
                            ${selectedTier === tier.id
                              ? "bg-white/[0.08] border-white/[0.15]"
                              : "bg-white/[0.04] border-white/[0.08] hover:bg-white/[0.06]"
                            }
                          `}
                        >
                          <div className="flex justify-between items-center mb-2">
                            <span className="font-medium text-white/90">{tier.name}</span>
                            <span className="text-sm text-white/70">{tier.price}</span>
                          </div>
                          <ul className="space-y-1">
                            {tier.features.map((feature, idx) => (
                              <li key={idx} className="text-xs text-white/60">• {feature}</li>
                            ))}
                          </ul>
                        </button>
                      ))}
                    </div>
                    
                    <button className="w-full mt-6 py-3 rounded-xl font-medium
                      bg-white/[0.08] border border-white/[0.1] text-white/90
                      hover:bg-white/[0.12] hover:border-white/[0.15]
                      active:bg-white/[0.06]
                      transition-all duration-200"
                    >
                      Get Started
                    </button>
                  </div>
                </div>
              )}
            </motion.div>

            {/* Archive Info Card */}
            <motion.div variants={cardVariants} className="w-full h-full min-h-[420px] order-2 lg:order-3">
              <InfoCard title="Archive">
                <motion.div
                  variants={contentFade}
                  initial="hidden"
                  animate="show"
                  transition={{ delay: 0.70 }}
                >
                  <p>
                    Archive is the retrieval layer for DartBoard. It lets you search across past sessions by keyword, jump
                    through time-bucketed slices, and quickly re-open the exact window of context where an idea happened.
                  </p>
                  <p>
                    It&apos;s built for recovering decisions, notes, and threads that would otherwise be lost to scrollback.
                    Think of it as your personal search engine for everything you&apos;ve discussed with the model.
                  </p>
                  <p>
                    Navigate by date, filter by topic, or search specific phrases to find exactly when and where a
                    conversation took place. Archive ensures your AI interactions become a searchable knowledge base rather
                    than ephemeral chat history.
                  </p>
                </motion.div>
              </InfoCard>
            </motion.div>
          </motion.div>
        </div>

        {/* Footer */}
        <div className="mt-12 text-center">
          <p className="text-sm text-white/30">v0.1 • Local Build • DartBoard System Hub</p>
        </div>
      </div>
    </div>
  )
}
